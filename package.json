{
	"name": "loadable-image",
	"version": "3.4.1",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/denchiklut/loadable-image.git"
	},
	"homepage": "https://denchiklut.github.io/loadable-image",
	"license": "MIT",
	"main": "dist/index.cjs.js",
	"module": "dist/index.esm.js",
	"module.esnext": "dist/esnext.esm.js",
	"types": "dist/@types/index.d.ts",
	"files": [
		"dist"
	],
	"description": "React Component to lazy load images",
	"author": "Karl: ollylut@gmail.com",
	"scripts": {
		"build": "rm -rf dist && NODE_ENV=production && rollup -c --bundleConfigAsCjs",
		"lint": "biome check --write --unsafe .",
		"typecheck": "tsc -p . --noEmit"
	},
	"dependencies": {
		"react-intersection-observer": "10.0.3",
		"transitions-kit": "1.4.0"
	},
	"peerDependencies": {
		"react": ">=16.6.0",
		"react-dom": ">=16.6.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@rollup/plugin-commonjs": "29.0.2",
		"@rollup/plugin-node-resolve": "16.0.3",
		"@rollup/plugin-typescript": "12.3.0",
		"@types/react": "19.2.14",
		"@types/react-transition-group": "4.4.12",
		"globals": "17.5.0",
		"lint-staged": "16.4.0",
		"rollup": "4.60.2",
		"rollup-plugin-peer-deps-external": "2.2.4",
		"rollup-plugin-terser": "7.0.2",
		"tslib": "2.8.1",
		"typescript": "6.0.3"
	},
	"keywords": [
		"react-intersection-observer",
		"intersection",
		"lazy",
		"lazy-image",
		"image",
		"loading",
		"loadable-image",
		"async-image",
		"uikit"
	]
}
